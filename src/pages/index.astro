---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Abogadas Lanús | Familia, Laboral y Sucesiones">
  
  <section id="inicio" class="relative bg-brand-dark text-white min-h-[90vh] md:min-h-screen flex items-center px-6 md:px-12 overflow-hidden pt-32 md:pt-40 pb-20 md:pb-24">

    <div class="absolute inset-0 z-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')]"></div>
    <div class="absolute top-1/2 right-0 md:-right-20 w-[30rem] md:w-[50rem] h-[30rem] md:h-[50rem] bg-brand-primary/15 rounded-full blur-[100px] md:blur-[130px] pointer-events-none z-0 -translate-y-1/2"></div>

    <div class="container mx-auto max-w-5xl relative z-10 w-full text-center md:text-left flex flex-col md:block items-center">

      <div class="inline-flex items-center gap-3 md:gap-4 mb-8 md:mb-10 bg-white/5 border border-white/10 rounded-full px-4 md:px-5 py-2 backdrop-blur-sm max-w-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 md:w-4 md:h-4 text-brand-primary shrink-0">
          <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
        </svg>
        <span class="text-white font-body text-[9px] md:text-[10px] tracking-widest uppercase font-bold truncate">
          TU RESPALDO LEGAL EN ZONA SUR
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-[5.5rem] font-heading font-bold leading-[1.1] md:leading-[1.05] mb-6 md:mb-8 text-white tracking-tight">
        Empatía para escucharte<span class="text-brand-primary">.</span> <br />
        <span class="italic font-light">Firmeza para defenderte<span class="text-brand-primary">.</span></span>
      </h1>

      <div class="md:border-l-4 md:border-brand-primary md:pl-8 mb-10 md:mb-12">
        <p class="text-base md:text-lg font-light text-gray-300 max-w-2xl leading-relaxed md:leading-loose">
          Brindamos asistencia legal de forma clara, directa y personal. Nos especializamos en Derecho de Familia, Sucesiones, Accidentes (ART) y Despidos.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row items-center gap-4 md:gap-8 w-full md:w-auto">
        <a href="#contacto" class="inline-flex items-center justify-center bg-brand-primary text-brand-dark px-8 md:px-12 py-4 md:py-5 font-body font-bold uppercase tracking-[0.2em] text-[10px] md:text-[11px] hover:bg-white transition-all duration-500 w-full sm:w-auto text-center shadow-lg shadow-brand-primary/20">
          Evaluá tu caso
        </a>
        <a href="#areas" class="inline-flex items-center justify-center gap-4 text-white hover:text-brand-primary transition-colors duration-300 font-body font-semibold text-[10px] md:text-[11px] uppercase tracking-[0.2em] px-4 py-4 w-full sm:w-auto group">
          <span class="w-8 h-px bg-white/30 group-hover:bg-brand-primary transition-colors hidden sm:block"></span>
          Ver Especialidades
        </a>
      </div>
    </div>
  </section>

  <div class="bg-brand-primary border-y border-brand-primary/80 relative z-20 shadow-xl">
    <div class="container mx-auto max-w-6xl px-6 py-4 md:py-5 flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-8 text-brand-dark font-body text-[10px] md:text-xs font-bold uppercase tracking-widest text-center">
      <span class="flex items-center justify-center gap-2 w-full sm:w-auto">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M19.916 4.626a.75.75 0 01.208 1.04l-9 13.5a.75.75 0 01-1.154.114l-6-6a.75.75 0 011.06-1.06l5.353 5.353 8.493-12.739a.75.75 0 011.04-.208z" clip-rule="evenodd" /></svg>
        Consulta inicial sin costo
      </span>
      <span class="hidden sm:block w-1.5 h-1.5 rounded-full bg-brand-dark/20"></span>
      <span class="flex items-center justify-center gap-2 w-full sm:w-auto">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-whatsapp" viewBox="0 0 16 16"> <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/></svg>
        Respondemos por WhatsApp en el día
      </span>
    </div>
  </div>

  <section id="areas" class="py-20 md:py-32 bg-[#F7F8F7] px-6 relative z-10">
    <div class="container mx-auto max-w-6xl">
      
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 md:mb-20 gap-6 md:gap-8">
        <div>
          <span class="text-brand-primary font-body font-bold tracking-[0.3em] uppercase text-[10px] md:text-xs mb-3 md:mb-4 block">Especialidades</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-brand-dark tracking-tight leading-[1.1]">Cómo podemos ayudarte.</h2>
        </div>
        <p class="text-base md:text-lg text-gray-500 font-light leading-relaxed md:leading-loose max-w-sm md:text-right border-l-2 md:border-l-0 md:border-r-2 border-brand-primary pl-4 md:pl-0 md:pr-4">
          Un abordaje humano para conflictos familiares y la máxima exigencia técnica en reclamos laborales.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        
        <div class="relative bg-brand-dark p-8 md:p-12 border border-white/10 overflow-hidden group transition-all duration-500 hover:-translate-y-1 shadow-2xl shadow-brand-primary/20">
          <div class="absolute top-0 right-0 w-64 h-64 bg-brand-primary/20 rounded-full blur-[80px] pointer-events-none group-hover:bg-brand-primary/30 transition-colors duration-500"></div>
          <div class="absolute -bottom-6 -right-2 text-[100px] md:text-[140px] font-heading font-bold text-white/5 group-hover:text-brand-primary/10 transition-colors duration-500 pointer-events-none select-none leading-none">01</div>
          
          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 mb-4">
              <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
              <span class="text-[10px] md:text-[11px] font-body font-bold text-white uppercase tracking-widest block">Beneficio Exclusivo</span>
            </div>
            
            <h3 class="text-2xl md:text-3xl font-heading font-bold text-white mb-6 leading-tight">Sucesiones <br/> Ágiles</h3>
            
            <ul class="space-y-4 text-sm md:text-base font-medium text-gray-300 mb-10">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Gestión completa y declaratoria de herederos</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span class="text-white font-bold tracking-wide">Planes de financiación a tu medida</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Protección del patrimonio familiar</span>
              </li>
            </ul>
            <div class="pt-6 border-t border-white/10">
              <a href="#contacto" class="inline-flex items-center gap-2 text-[10px] md:text-xs font-body font-bold uppercase tracking-[0.2em] text-white group-hover:text-brand-primary transition-colors">
                Consultar Sucesión <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="relative bg-white p-8 md:p-12 border border-gray-100 overflow-hidden group transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] hover:-translate-y-1">
          <div class="absolute top-0 left-0 w-0 h-1 bg-brand-primary transition-all duration-500 group-hover:w-full"></div>
          <div class="absolute -bottom-6 -right-2 text-[100px] md:text-[140px] font-heading font-bold text-gray-50 group-hover:text-brand-primary/5 transition-colors duration-500 pointer-events-none select-none leading-none">02</div>
          <div class="relative z-10">
            <h3 class="text-2xl md:text-3xl font-heading font-bold text-brand-dark mb-6 leading-tight">Derecho <br/> de Familia</h3>
            <ul class="space-y-4 text-sm md:text-base font-medium text-gray-600 mb-10">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Divorcios (Mutuo acuerdo o contradictorios)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Cuota Alimentaria y Cuidado Personal</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Régimen de Comunicación (Visitas)</span>
              </li>
            </ul>
            <div class="pt-6 border-t border-gray-100">
              <a href="#contacto" class="inline-flex items-center gap-2 text-[10px] md:text-xs font-body font-bold uppercase tracking-[0.2em] text-brand-dark group-hover:text-brand-primary transition-colors">
                Consultar caso <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="relative bg-white p-8 md:p-12 border border-gray-100 overflow-hidden group transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] hover:-translate-y-1">
          <div class="absolute top-0 left-0 w-0 h-1 bg-brand-primary transition-all duration-500 group-hover:w-full"></div>
          <div class="absolute -bottom-6 -right-2 text-[100px] md:text-[140px] font-heading font-bold text-gray-50 group-hover:text-brand-primary/5 transition-colors duration-500 pointer-events-none select-none leading-none">03</div>
          <div class="relative z-10">
            <h3 class="text-2xl md:text-3xl font-heading font-bold text-brand-dark mb-6 leading-tight">Accidentes <br/> de Trabajo</h3>
            <ul class="space-y-4 text-sm md:text-base font-medium text-gray-600 mb-10">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Reclamos contra la ART</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Accidentes "In Itinere" (En el trayecto)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Enfermedades profesionales</span>
              </li>
            </ul>
            <div class="pt-6 border-t border-gray-100">
              <a href="#contacto" class="inline-flex items-center gap-2 text-[10px] md:text-xs font-body font-bold uppercase tracking-[0.2em] text-brand-dark group-hover:text-brand-primary transition-colors">
                Consultar caso <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="relative bg-white p-8 md:p-12 border border-gray-100 overflow-hidden group transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] hover:-translate-y-1">
          <div class="absolute top-0 left-0 w-0 h-1 bg-brand-primary transition-all duration-500 group-hover:w-full"></div>
          <div class="absolute -bottom-6 -right-2 text-[100px] md:text-[140px] font-heading font-bold text-gray-50 group-hover:text-brand-primary/5 transition-colors duration-500 pointer-events-none select-none leading-none">04</div>
          <div class="relative z-10">
            <h3 class="text-2xl md:text-3xl font-heading font-bold text-brand-dark mb-6 leading-tight">Despidos e <br/> Indemnizaciones</h3>
            <ul class="space-y-4 text-sm md:text-base font-medium text-gray-600 mb-10">
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Trabajo no registrado (En negro)</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Despidos sin causa justificada</span>
              </li>
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 md:w-5 md:h-5 text-brand-primary shrink-0"><path fill-rule="evenodd" d="M16.403 12.652a3 3 0 000-5.304 3 3 0 00-3.75-3.751 3 3 0 00-5.305 0 3 3 0 00-3.751 3.75 3 3 0 000 5.305 3 3 0 003.75 3.751 3 3 0 005.305 0 3 3 0 003.751-3.75zm-2.546-4.46a.75.75 0 00-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
                <span>Diferencias salariales y horas extras</span>
              </li>
            </ul>
